.fa-sharp-duotone.fa-regular::after, .fasdr::after { color: var(--fa-secondary-color,inherit); opacity: var(--fa-secondary-opacity,.4); }

.fa-sharp-duotone.fa-regular.fa-swap-opacity::before, .fa-sharp-duotone.fa-swap-opacity::before, .fa-swap-opacity .fa-sharp-duotone.fa-regular::before, .fa-swap-opacity .fasdr::before, .fasdr.fa-swap-opacity::before { opacity: var(--fa-secondary-opacity,.4); }

