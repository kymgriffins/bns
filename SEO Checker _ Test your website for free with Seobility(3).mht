.fa-sharp-duotone.fa-regular.fa-inverse, .fasdr.fa-inverse { color: var(--fa-inverse,#fff); }

.fa-sharp-duotone.fa-regular.fa-stack-1x, .fa-sharp-duotone.fa-regular.fa-stack-2x, .fasdr.fa-stack-1x, .fasdr.fa-stack-2x { position: absolute; }

