@charset "utf-8";

.seobility-marketing-slot { color: rgb(255, 255, 255); font-family: Graphik; background-color: rgb(29, 133, 237); background-image: url("./assets/seobility-banner-desktop.png"); background-size: cover; border-radius: 8px; }

.seobility-marketing-slot.alternative { background-image: url("./assets/seobility-banner-desktop-alternative.png"); }

.seobility-marketing-slot p, .seobility-marketing-slot .seobility-marketing-slot-column-title, .seobility-marketing-slot .seobility-marketing-slot-column-list { margin: 0px; }

.seobility-marketing-slot-content { min-height: 440px; display: flex; gap: 50px; flex-direction: row; justify-content: space-between; align-items: center; }

.seobility-marketing-slot-extra-title { font-size: 16px; font-style: normal; font-weight: 600; line-height: 22px; }

.seobility-marketing-slot-column-title { font-size: 32px; font-style: normal; font-weight: 600; line-height: 40px; }

.seobility-marketing-slot-column-list-text, .seobility-marketing-slot-column-list { font-size: 16px; font-style: normal; font-weight: 400; line-height: 22px; }

.seobility-marketing-slot-column-list { padding-left: 20px; display: grid; grid-template-columns: 1fr 1fr; }

.seobility-marketing-slot-column-list li { list-style-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='6' cy='6' r='6' fill='%232BC46A'/%3E%3Cpath d='M10.75 3.78906L10.418 4.12109L5.45703 9.0625L5.125 9.39453L4.79297 9.0625L2.33203 6.60156L2 6.26953L2.64453 5.60547L2.97656 5.9375L5.125 8.06641L9.75391 3.45703L10.0859 3.125L10.75 3.78906Z' fill='white'/%3E%3C/svg%3E"); }

.seobility-marketing-slot-column-list li:not(:last-child) { margin-bottom: 4px; }

.seobility-marketing-slot-column { height: 100%; box-sizing: border-box; width: 58%; }

.seobility-marketing-slot-column-content-wrapper { gap: 12px; display: flex; flex-direction: column; justify-content: center; padding: 35px 0px 35px 35px; }

.seobility-marketing-slot-column-image { align-self: flex-end; align-content: end; width: 42%; }

.seobility-marketing-slot-image { padding: 23px 0px 23px 23px; height: fit-content; border-radius: 20px 0px 0px; background: rgba(214, 235, 255, 0.5); }

.seobility-marketing-slot.alternative .seobility-marketing-slot-image { border-radius: 0px 20px 0px 0px; padding: 23px 23px 23px 0px; }

.seobility-marketing-slot.alternative .seobility-marketing-slot-content { flex-direction: row-reverse; }

.seobility-marketing-slot.alternative .seobility-marketing-slot-column-content-wrapper { padding: 35px 35px 35px 0px; }

.seobility-marketing-slot-image img { width: 100%; height: 100%; object-fit: contain; }

.seobility-marketing-slot-column-list-actions { margin-top: 12px; }

.seobility-marketing-slot-column-buttons { display: flex; flex-wrap: nowrap; gap: 15px; }

.seobility-marketing-slot-column-buttons a { display: inline-flex; height: 52px; padding: 13px 21px; justify-content: center; align-items: center; color: white; text-decoration: none; box-sizing: border-box; font-size: 16px; font-style: normal; font-weight: 500; line-height: 22px; }

.seobility-marketing-slot-column-buttons a.seobility-marketing-slot-column-button-primary { border-radius: 8px; background: rgb(43, 196, 106); box-shadow: rgba(19, 92, 164, 0.15) 3px 3px 20px 1px; }

.seobility-marketing-slot-column-buttons a.seobility-marketing-slot-column-button-secondary { border-radius: 8px; border: 1px solid rgb(255, 255, 255); }

.seobility-marketing-slot-column-chips { display: flex; justify-content: flex-start; flex-wrap: wrap; gap: 9px; align-items: center; }

.seobility-marketing-slot-column-chip-separator { width: 5px; height: 5px; border-radius: 50%; background-color: rgb(214, 235, 255); display: inline-block; }

.seobility-marketing-slot-column-chip { color: rgb(214, 235, 255); font-size: 10px; font-style: normal; font-weight: 500; line-height: normal; }

@media (max-width: 1279px) {
