# Supabase Configuration (REQUIRED for production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Application URL
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# =============================================
# EMAIL CONFIGURATION (from emailconfig.md)
# =============================================

# SMTP Settings (Recommended - Secure SSL/TLS)
# Incoming Server: mail.budgetndiostory.org
# IMAP Port: 993 | POP3 Port: 995
# Outgoing Server: mail.budgetndiostory.org
# SMTP Port: 465 (uses SSL/TLS)
# Authentication required for IMAP, POP3, and SMTP

# SMTP Configuration
SMTP_HOST=mail.budgetndiostory.org
SMTP_PORT=465
SMTP_USER=info@budgetndiostory.org
SMTP_PASS=@budgetndiostory.org

# Email Sender
SMTP_FROM=Budget Ndio Story <info@budgetndiostory.org>
SMTP_FROM_NAME=Budget Ndio Story
DEFAULT_EMAIL_FROM=Budget Ndio Story <info@budgetndiostory.org>

# Alternative Email Variables (also supported)
EMAIL_HOST=mail.budgetndiostory.org
EMAIL_PORT=465
EMAIL_USER=info@budgetndiostory.org

# Admin notification email
ADMIN_EMAIL=admin@budgetndiostory.org

# Resend API (optional - will use SMTP if configured above)
# Get your API key from https://resend.com
# RESEND_API_KEY=re_123456789

# =============================================
# MARKETING & ANALYTICS CONFIGURATION
# =============================================

# Google Analytics 4
# Get your GA4 ID from Google Analytics Admin > Data Streams
#NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Facebook Pixel
# Get your Pixel ID from Facebook Events Manager
#NEXT_PUBLIC_FACEBOOK_PIXEL_ID=1234567890

# Google Ads Conversion Tracking
# Get your Ads ID from Google Ads
#NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX

# TikTok Pixel (optional)
#NEXT_PUBLIC_TIKTOK_PIXEL_ID=XXXXXXXXXX

# Twitter Analytics (optional)
#NEXT_PUBLIC_TWITTER_PIXEL_ID=XXXXXX

# LinkedIn Insight Tag (optional)
#NEXT_PUBLIC_LINKEDIN_PARTNER_ID=XXXXXX

# Hotjar Analytics (optional - for user behavior insights)
#NEXT_PUBLIC_HOTJAR_ID=XXXXXX

# =============================================
# MARKETING DATA COLLECTION SETTINGS
# =============================================

# Enable/disable marketing data collection (default: true when IDs are set)
# Set to 'false' to disable all marketing tracking
#NEXT_PUBLIC_MARKETING_ENABLED=true

# Cookie consent banner settings
# Options: 'banner' | 'modal' | 'hidden'
#NEXT_PUBLIC_COOKIE_CONSENT_MODE=banner

# Cookie expiry days (default: 365)
#NEXT_PUBLIC_COOKIE_EXPIRY_DAYS=365

# =============================================
# CHAT WIDGET SETTINGS
# =============================================

# Hide the AI chat widget (default: false)
# Set to 'true' to hide the chat widget from the site
#NEXT_PUBLIC_HIDE_CHAT_WIDGET=true

# =============================================
# MEDIA / PODCAST
# =============================================

# YouTube link for the first podcast series shown on the landing page.
# Can be a playlist URL, channel URL, or a specific video URL.
NEXT_PUBLIC_YOUTUBE_PODCAST_URL=https://www.youtube.com/playlist?list=YOUR_PLAYLIST_ID

# =============================================
# YOUTUBE API CONFIGURATION
# =============================================
# Get your API key from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3"
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# Your YouTube Channel ID (starts with UC)
# Find it at: youtube.com/account_advanced
YOUTUBE_CHANNEL_ID=UCYourChannelId

# Alternative: Use channel handle (starts with @)
# YOUTUBE_CHANNEL_HANDLE=@YourChannelHandle

# Maximum videos to fetch per request (default: 20)
YOUTUBE_MAX_VIDEOS=20

# Auto-generate transcripts and key takeaways (requires API key)
YOUTUBE_AUTO_TRANSCRIPT=true

# OpenAI API Key for generating key takeaways
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY