# ============================================================
# Budget Ndio Story · Environment Variables
# Copy to .env.local for local dev.
# Add ALL of these to Vercel → Project → Settings → Environment Variables
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://budgetndiostory.org

# ── cPanel SMTP (Nodemailer) ─────────────────────────────────
SMTP_HOST=mail.budgetndiostory.org
SMTP_PORT=465
SMTP_USER=info@budgetndiostory.org
SMTP_PASSWORD=@budgetndiostory.org
SMTP_FROM=Budget Ndio Story <info@budgetndiostory.org>

# ── cPanel MySQL ─────────────────────────────────────────────
# DB_HOST: your cPanel server IP, or localhost if backend is on same cPanel server
# For Vercel → cPanel: use your server's public IP, not localhost
DB_HOST=YOUR_CPANEL_SERVER_IP
DB_PORT=3306
DB_USER=YOUR_CPANEL_DB_USERNAME
DB_PASSWORD=YOUR_CPANEL_DB_PASSWORD
DB_NAME=YOUR_DATABASE_NAME
DB_SSL=false

# ── Admin ─────────────────────────────────────────────────────
# Email that receives tip and report request notifications
ADMIN_EMAIL=info@budgetndiostory.org
