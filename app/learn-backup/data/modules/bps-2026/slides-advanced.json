            "letter": "A",
            "text": "January 1st"
          },
          {
            "letter": "B",
            "text": "February 15th"
          },
          {
            "letter": "C",
            "text": "March 30th"
          },
          {
            "letter": "D",
            "text": "April 30th"
          }
        ],
        "correct": 1,
        "feedback": {
          "correct": "✅ Correct! The BPS must be submitted by February 15th each year per Section 25 of the PFM Act.",
          "wrong": "❌ Not quite. The deadline is February 15th - any later would be a legal violation."
        }
